<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="Project.add_orderController" spacing="0" VBox.vgrow="ALWAYS">
    <children>
        <HBox spacing="10" style="-fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10" />
            </padding>
            <children>
                <Button fx:id="main_menuButton" text="Main Menu" onAction="#sceneChange_mainMenu" />
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="titleField" text="Add Order" editable="true" prefWidth="300">
                    <font>
                        <Font size="24" />
                    </font>
                </TextField>
            </children>
        </HBox>

        <HBox spacing="10" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10" />
            </padding>
            <children>
                <GridPane hgap="10" vgap="10" prefWidth="300">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" halignment="RIGHT" prefWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <children>
                        <Label text="Customer Name :" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <TextField fx:id="customer_nameField" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                        <Label text="Street Address :" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <TextField fx:id="street_addressField" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                        <Label text="Zip :" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <TextField fx:id="zip_field" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                        <Label text="State :" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                        <TextField fx:id="state_field" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                        <Label text="City :" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                        <TextField fx:id="city_field" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                        <Label text="Delivery Hours :" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                        <TextField fx:id="delivery_hoursField" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                        <Label text="Loading Dock Capability :" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                        <CheckBox fx:id="loading_yesCapability" GridPane.rowIndex="6" GridPane.columnIndex="1" onAction="#compatibilityChecker" />
                    </children>
                </GridPane>

                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <children>
                        <VBox spacing="4">
                            <Label text="Product ID" style="-fx-font-weight: bold;" />
                            <ComboBox fx:id="autofill_productID" editable="true" />
                            <Label text="Product Sub Name" style="-fx-font-weight: bold;" />
                            <TextField fx:id="autofill_subName" />
                        </VBox>

                        <VBox spacing="4">
                            <Label text="Quantity" style="-fx-font-weight: bold;" />
                            <HBox spacing="6">
                                <TextField fx:id="quantity_textField" prefWidth="120" />
                                <Button fx:id="adding_listButton" text="Add" onAction="#setAdding_listButton" />
                            </HBox>
                        </VBox>

                        <HBox spacing="6">
                            <Button fx:id="show_listButton" text="Show List" onAction="#sceneChange_list" />
                            <Button fx:id="submit_listButton" text="Submit" onAction="#sceneChange_submit" />
                        </HBox>

                        <Region VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
