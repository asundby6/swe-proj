<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="main_menuScene" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Project.menuController">
   <children>
      <BorderPane fx:id="mainBorder" prefHeight="400.0" prefWidth="600.0" />
      <Button fx:id="sign_outButton" layoutX="500.0" layoutY="2.0" mnemonicParsing="false" onAction="#handleSignOutButtonClick" prefHeight="25.0" prefWidth="100.0" text="Sign Out" />
      <TextField alignment="CENTER" layoutX="100.0" layoutY="2.0" prefHeight="65.0" prefWidth="350.0" text="Main Menu">
         <font>
            <Font size="30.0" />
         </font>
      </TextField>
      <Button fx:id="manage_customersButton" layoutX="171.0" layoutY="260.0" mnemonicParsing="false" prefHeight="47.0" prefWidth="207.0" text="Manage Customers" />
      <Button fx:id="add_orderButton" layoutX="172.0" layoutY="134.0" mnemonicParsing="false" onAction="#sceneChange_addOrder" prefHeight="47.0" prefWidth="207.0" text="Add Order">
      </Button>
      <Button fx:id="manage_ordersButton" layoutX="171.0" layoutY="200.0" mnemonicParsing="false" prefHeight="47.0" prefWidth="207.0" text="Manage Orders" />
   </children>
</AnchorPane>
