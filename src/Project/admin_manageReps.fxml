<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="admin_menuScene" prefHeight="400.0" prefWidth="600.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Project.admin_managerController">
    <children>
        <Button fx:id="sign_outButton" layoutX="500.0" layoutY="2.0" mnemonicParsing="false" onAction="#handleSignOutButtonClick" prefHeight="25.0" prefWidth="100.0" text="Sign out" />
        <TextField alignment="CENTER" layoutX="125.0" layoutY="2.0" prefHeight="65.0" prefWidth="350.0" text="Admin Menu">
            <font>
                <Font size="30.0" />
            </font>
        </TextField>
        <Button fx:id="admin_toolsButton" layoutX="157.0" layoutY="158.0" mnemonicParsing="false" onAction="#handleAdminToolsButtonClick" prefHeight="84.0" prefWidth="286.0" text="Admin Tools">
            <font>
                <Font size="24.0" />
            </font>
        </Button>
    </children>
</AnchorPane>
